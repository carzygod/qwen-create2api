# Network
HOST=0.0.0.0
PORT=19091
PUBLIC_BASE_URL=http://127.0.0.1:19091

# Guest pool fallback. Keep 0 for QR/login account-pool deployments.
POOL_SIZE=0
REFRESH_HOURS=10

# Authentication
AUTH_KEY=change-me-api-key
ADMIN_KEY=change-me-admin-key

# Storage
DATA_DIR=./data
DATABASE_PATH=./data/qianwen-creator-01.sqlite

# Defaults exposed by /v1/models.
DEFAULT_CHAT_MODEL=qianwen-creator-session
DEFAULT_IMAGE_MODEL=qianwen-creator-wan27-image
DEFAULT_VIDEO_MODEL=qianwen-creator-wan22-flash-frame

# Logging
LOG_LEVEL=info
